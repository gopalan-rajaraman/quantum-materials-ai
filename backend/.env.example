# Server Configuration
ENV=development
VERSION=1.0.0

# Security (MUST CHANGE IN PRODUCTION)
JWT_SECRET_KEY="replace-with-a-very-long-secure-random-string"
JWT_ALGORITHM="HS256"

# Database Configuration
MONGODB_URL="mongodb+srv://username:password@cluster.mongodb.net/?appName=App"
DATABASE_NAME="bo_loop_db"

# SMTP Configuration (for sending emails)
SMTP_HOST="smtp.resend.com"
SMTP_PORT=587
SMTP_USER="resend"
SMTP_PASSWORD="your-resend-api-key"
FROM_NAME="Quantum Materials AI"
FROM_EMAIL="noreply@quantummaterials.ai"

# Frontend Configuration
FRONTEND_URL="http://localhost:5173"

# OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id"
